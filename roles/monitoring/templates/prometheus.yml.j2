global:
  scrape_interval: 15s
  evaluation_interval: 15s

scrape_configs:
  - job_name: node_lab
    static_configs:
      - targets: ['192.168.1.10:9100']

  - job_name: node_unifi
    static_configs:
      - targets: ['192.168.1.2:9100']

  - job_name: node_pi
    static_configs:
      - targets: ['192.168.1.251:9100']

  - job_name: pihole_lab
    static_configs:
      - targets: ['{{ pihole_exporter_ip }}:9617']

  - job_name: pihole_pi
    static_configs:
      - targets: ['192.168.1.251:9617']
