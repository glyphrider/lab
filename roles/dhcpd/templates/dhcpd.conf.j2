default-lease-time {{ dhcpd_default_lease_time }};
max-lease-time {{ dhcpd_max_lease_time }};

option domain-name "{{ dhcpd_domain_name }}";

{% for subnet in dhcpd_subnets %}
subnet {{ subnet.subnet }} netmask {{ subnet.netmask }} {
	range {{ subnet.range[0] }} {{ subnet.range[1] }};
	option routers {{ subnet.routers }};
	option domain-name-servers {{ subnet.dns | join(', ') }};
{% for host in subnet.hosts | default([]) %}
	host {{ host.name }} {
		hardware ethernet {{ host.mac }};
		fixed-address {{ host.ip }};
	}
{% endfor %}
}
{% endfor %}
