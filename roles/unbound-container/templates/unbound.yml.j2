services:
  unbound:
    container_name: unbound
    image: localhost/unbound:latest
    volumes:
      - '{{ unbound_container_conf_dir }}/unbound.conf:/etc/unbound/unbound.conf:ro'
      - '{{ unbound_container_conf_dir }}/root.hints:/etc/unbound/root.hints:ro'
    networks:
{% for instance in unbound_container_instances %}
      {{ instance.network }}:
        ipv4_address: {{ instance.ip }}
{% endfor %}
    restart: unless-stopped
    healthcheck:
      test: ["CMD", "dig", "@127.0.0.1", "cloudflare.com", "+short", "+time=3", "+tries=1"]
      interval: 30s
      timeout: 5s
      retries: 3
      start_period: 10s

networks:
{% for instance in unbound_container_instances %}
  {{ instance.network }}:
    external: true
{% endfor %}
